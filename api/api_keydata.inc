        'upper' => "ГҖ ГӮ Г„ ГҶ ГҲ Гү ГҠ ГӢ ГҺ ГҸ Г” Г– Гҷ Гӣ Гң 0 ГҮ 0",
        'lower' => "Г  Гў ГӨ ГҰ ГЁ Г© ГӘ Г« Г® ГҜ Гҙ Г¶ Г№ Г» Гј Гҹ Г§ Гҝ"
        ),
    array(
        'code' =>'В¶',
        'upper' => "В¶ В° Вә В·",
        'lower' => "В§ 0 ВЈ"
        )
    );

    $project = new Project($project_id);
